---
/** Água-viva 3D fixa atrás do conteúdo — reage a scroll e cursor. */
---

<canvas id="jellyfish-canvas" class="jellyfish-canvas" aria-hidden="true"></canvas>

<script>
  import { markWebGLFallback } from '../scripts/jellyfish/webgl';

  const canvas = document.getElementById('jellyfish-canvas') as HTMLCanvasElement | null;
  if (!canvas) throw new Error('jellyfish-canvas missing');

  async function bootJellyfish() {
    try {
      document.documentElement.classList.remove('no-webgl');
      canvas.hidden = false;
      const { initJellyfishScene } = await import('../scripts/jellyfish/index');
      const destroy = initJellyfishScene(canvas);
      document.addEventListener('astro:before-swap', () => destroy(), { once: true });
    } catch (error) {
      console.error('[jellyfish] init failed', error);
      markWebGLFallback('init-error', canvas);
    }
  }

  void bootJellyfish();
</script>
